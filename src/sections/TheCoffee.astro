---
import Container from '../components/Container.astro';
import FadeIn from '../components/FadeIn';
---

<section class="py-20 sm:py-28 bg-warm-sand">
  <Container>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <FadeIn client:visible direction="left">
        <div class="aspect-[4/3] rounded-2xl overflow-hidden bg-coconut-cream shadow-lg">
          <img
            src="/images/dishes/dtimer-coffee.jpg"
            alt="D'Timer Iced Coffee in a tall glass with condensed milk"
            class="w-full h-full object-cover"
            loading="lazy"
            onerror="this.src='https://images.unsplash.com/photo-1461023058943-07fcbe16d735?w=800&q=80'"
          />
        </div>
      </FadeIn>

      <div>
        <FadeIn client:visible direction="right">
          <p class="text-xs sm:text-sm font-body font-medium tracking-[0.25em] uppercase text-sambal-red">
            And don't skip the coffee
          </p>
        </FadeIn>

        <FadeIn client:visible delay={0.15} direction="right">
          <h2 class="mt-3 font-display text-3xl sm:text-4xl lg:text-5xl font-semibold text-warm-black leading-tight">
            Brewed strong.<br />Served cold.
          </h2>
        </FadeIn>

        <FadeIn client:visible delay={0.3} direction="right">
          <p class="mt-5 text-base sm:text-lg text-tea-brown leading-relaxed">
            The D'Timer Iced Coffee is brewed strong, mixed with condensed milk, served cold. 
            Old-school Johor cafe tradition. Pairs with everything — from a heavy Laksa Johor 
            to a light afternoon Roti Bakar.
          </p>
        </FadeIn>

        <FadeIn client:visible delay={0.45} direction="right">
          <div class="mt-6 flex flex-wrap gap-4">
            <span class="inline-flex items-center gap-2 text-sm text-tea-brown bg-bone-white px-4 py-2 rounded-full">
              <span class="w-1.5 h-1.5 rounded-full bg-turmeric-gold"></span>
              Condensed milk
            </span>
            <span class="inline-flex items-center gap-2 text-sm text-tea-brown bg-bone-white px-4 py-2 rounded-full">
              <span class="w-1.5 h-1.5 rounded-full bg-turmeric-gold"></span>
              Strong brew
            </span>
            <span class="inline-flex items-center gap-2 text-sm text-tea-brown bg-bone-white px-4 py-2 rounded-full">
              <span class="w-1.5 h-1.5 rounded-full bg-turmeric-gold"></span>
              Johor style
            </span>
          </div>
        </FadeIn>
      </div>
    </div>
  </Container>
</section>
