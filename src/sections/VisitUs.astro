---
import Container from '../components/Container.astro';
import Button from '../components/Button.astro';
import FadeIn from '../components/FadeIn';
import siteData from '../data/site.json';
import { MapPin, Clock, Phone, Car } from 'lucide-react';
---

<section id="visit" class="py-20 sm:py-28 bg-warm-sand">
  <Container>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
      <FadeIn client:visible direction="up">
        <div class="rounded-2xl overflow-hidden bg-coconut-cream aspect-video shadow-lg">
          <iframe
            src={siteData.google.mapsEmbed}
            title="D'Timer Cafe location map"
            class="w-full h-full border-0"
            loading="lazy"
            allowfullscreen
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </FadeIn>

      <div>
        <FadeIn client:visible direction="up">
          <p class="text-xs sm:text-sm font-body font-medium tracking-[0.25em] uppercase text-sambal-red">
            Visit Us
          </p>
          <h2 class="mt-3 font-display text-3xl sm:text-4xl font-semibold text-warm-black leading-tight">
            Come find us in Wangsa Maju.
          </h2>
        </FadeIn>

        <FadeIn client:visible delay={0.15} direction="up">
          <div class="mt-8 space-y-5">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-lg bg-sambal-red/10 flex items-center justify-center flex-shrink-0">
                <MapPin size={18} class="text-sambal-red" />
              </div>
              <div>
                <h4 class="font-medium text-warm-black">Address</h4>
                <p class="mt-1 text-sm text-tea-brown leading-relaxed">
                  {siteData.address.street}<br />
                  {siteData.address.road}, {siteData.address.section}<br />
                  {siteData.address.area}, {siteData.address.postcode} {siteData.address.city}
                </p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-lg bg-sambal-red/10 flex items-center justify-center flex-shrink-0">
                <Clock size={18} class="text-sambal-red" />
              </div>
              <div>
                <h4 class="font-medium text-warm-black">Opening Hours</h4>
                <div class="mt-1 text-sm text-tea-brown space-y-1">
                  <p>Sunday – Thursday: 2:30pm – 11:00pm</p>
                  <p>Friday – Saturday: 2:30pm – 12:00am</p>
                </div>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-lg bg-sambal-red/10 flex items-center justify-center flex-shrink-0">
                <Phone size={18} class="text-sambal-red" />
              </div>
              <div>
                <h4 class="font-medium text-warm-black">Phone</h4>
                <p class="mt-1 text-sm text-tea-brown">
                  <a href={`tel:${siteData.phone.replace(/\s/g, '')}`} class="hover:text-sambal-red transition-colors">
                    {siteData.phone}
                  </a>
                </p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-lg bg-sambal-red/10 flex items-center justify-center flex-shrink-0">
                <Car size={18} class="text-sambal-red" />
              </div>
              <div>
                <h4 class="font-medium text-warm-black">Parking</h4>
                <p class="mt-1 text-sm text-tea-brown">
                  Street parking available along Jalan Maju Ria 2. 
                  Plaza Wangsa Maju basement parking accessible from the main road.
                </p>
              </div>
            </div>
          </div>
        </FadeIn>

        <FadeIn client:visible delay={0.3} direction="up">
          <div class="mt-8">
            <Button
              href={`https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(`D'Timer Cafe, ${siteData.address.street}, ${siteData.address.city}`)}`}
              variant="primary"
              target="_blank"
              rel="noopener noreferrer"
            >
              Get Directions
            </Button>
          </div>
        </FadeIn>
      </div>
    </div>
  </Container>
</section>
