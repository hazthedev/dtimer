---
import Container from '../components/Container.astro';
import FadeIn from '../components/FadeIn';
---

<section class="py-16 sm:py-24 bg-warm-sand">
  <Container>
    <FadeIn client:visible>
      <div class="max-w-3xl mx-auto text-center">
        <p class="text-xs sm:text-sm font-body font-medium tracking-[0.25em] uppercase text-sambal-red">
          Our Story
        </p>
        <h1 class="mt-4 font-display text-4xl sm:text-5xl lg:text-6xl font-bold text-warm-black leading-tight">
          We brought Johor to Wangsa Maju in 2008.
        </h1>
        <p class="mt-5 text-base sm:text-lg text-tea-brown leading-relaxed">
          A family kitchen that grew into a gathering place. 
          Recipes from the south, served with pride in the heart of KL.
        </p>
      </div>
    </FadeIn>
  </Container>
</section>
