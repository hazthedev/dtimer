---
import Container from '../components/Container.astro';
import FadeIn from '../components/FadeIn';
import ContactForm from '../components/ContactForm';
---

<section class="py-20 sm:py-28 bg-warm-sand">
  <Container>
    <div class="max-w-2xl mx-auto">
      <FadeIn client:visible>
        <div class="text-center mb-10">
          <p class="text-xs sm:text-sm font-body font-medium tracking-[0.25em] uppercase text-sambal-red">
            Get in Touch
          </p>
          <h2 class="mt-3 font-display text-3xl sm:text-4xl font-semibold text-warm-black leading-tight">
            Send us a message.
          </h2>
          <p class="mt-3 text-base text-tea-brown">
            For table holds, catering orders, or to ask if Lontong Darat is on today.
          </p>
        </div>
      </FadeIn>

      <FadeIn client:visible delay={0.15}>
        <div class="bg-bone-white rounded-2xl p-6 sm:p-10 shadow-sm border border-coconut-cream/50">
          <ContactForm client:visible />
        </div>
      </FadeIn>
    </div>
  </Container>
</section>
