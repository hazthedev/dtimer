---
import Container from '../components/Container.astro';
import FadeIn from '../components/FadeIn';
import siteData from '../data/site.json';
import { ShoppingBag } from 'lucide-react';
---

<section class="py-16 sm:py-20 bg-bone-white">
  <Container>
    <FadeIn client:visible>
      <div class="text-center">
        <p class="text-xs sm:text-sm font-body font-medium tracking-[0.25em] uppercase text-sambal-red">
          Follow Along
        </p>
        <h2 class="mt-3 font-display text-2xl sm:text-3xl font-semibold text-warm-black">
          @dtimercafe
        </h2>
        <p class="mt-2 text-base text-tea-brown max-w-md mx-auto">
          Daily specials, behind-the-scenes, and the occasional Laksa Johor pour.
        </p>
      </div>
    </FadeIn>

    <FadeIn client:visible delay={0.15}>
      <div class="mt-10 flex flex-wrap justify-center gap-4">
        <a
          href={siteData.social.instagram}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-warm-sand text-warm-black px-6 py-3 rounded-lg font-medium hover:bg-coconut-cream transition-colors"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
          Instagram
        </a>
        <a
          href={siteData.social.facebook}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-warm-sand text-warm-black px-6 py-3 rounded-lg font-medium hover:bg-coconut-cream transition-colors"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          Facebook
        </a>
        <a
          href={siteData.delivery.foodpanda}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-[#D70F64] text-white px-6 py-3 rounded-lg font-medium hover:bg-[#b80d55] transition-colors"
        >
          <ShoppingBag size={18} />
          FoodPanda
        </a>
        <a
          href={siteData.delivery.grabfood}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-[#00B14F] text-white px-6 py-3 rounded-lg font-medium hover:bg-[#009940] transition-colors"
        >
          <ShoppingBag size={18} />
          GrabFood
        </a>
      </div>
    </FadeIn>
  </Container>
</section>
