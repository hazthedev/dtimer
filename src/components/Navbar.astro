---
import Container from './Container.astro';
import { Menu, X, Phone } from 'lucide-react';

const navLinks = [
  { label: 'Home',  href: '/',       code: '01' },
  { label: 'Menu',  href: '/menu',   code: '02' },
  { label: 'Story', href: '/story',  code: '03' },
];

const whatsappNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER || '60182035828';
const whatsappLink = `https://wa.me/${whatsappNumber}?text=Hi%20D'Timer%20Cafe!%20I'd%20like%20to%20ask%20about...`;
---

<a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[60] bg-sambal-red text-warm-black px-4 py-2 font-body font-bold tracking-[0.2em] uppercase text-xs">
  Skip to content
</a>

<header id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-200 bg-warm-black border-b border-coconut-cream/15">
  <Container>
    <nav class="flex items-center justify-between h-14 sm:h-16">
      <!-- Logo lockup -->
      <a href="/" class="group inline-flex items-center gap-3">
        <span class="relative inline-block w-8 h-8 border border-sambal-red">
          <span class="absolute inset-0 m-auto w-1.5 h-1.5 bg-sambal-red rounded-full"></span>
          <span class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-0.5 h-3 bg-bone-white origin-bottom rotate-[35deg] tick-second"></span>
        </span>
        <span class="font-display text-lg sm:text-xl text-bone-white group-hover:text-sambal-red transition-colors tracking-[0.05em]">
          D'TIMER
        </span>
        <span class="hidden sm:inline-block font-body text-[0.65rem] tracking-[0.3em] uppercase text-coconut-cream/50 border-l border-coconut-cream/20 pl-3 ml-1">
          EST. 2008
        </span>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-1">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="group relative px-4 py-2 font-body text-[0.7rem] tracking-[0.3em] uppercase text-coconut-cream/80 hover:text-sambal-red transition-colors"
          >
            <span class="text-sambal-red mr-2 tabular-nums">{link.code}</span>
            <span>{link.label}</span>
            <span class="absolute left-3 right-3 -bottom-px h-px bg-sambal-red origin-left scale-x-0 group-hover:scale-x-100 transition-transform duration-200" />
          </a>
        ))}
        <a
          href={whatsappLink}
          target="_blank"
          rel="noopener noreferrer"
          class="ml-3 inline-flex items-center gap-2 bg-sambal-red text-warm-black px-4 py-2.5 font-body text-[0.7rem] tracking-[0.25em] uppercase font-bold border border-sambal-red hover:bg-warm-black hover:text-sambal-red transition-colors"
        >
          <Phone size={13} />
          <span>WhatsApp</span>
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 text-bone-white hover:text-sambal-red transition-colors border border-coconut-cream/20"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <Menu id="menu-icon" size={20} />
        <X id="close-icon" size={20} class="hidden" />
      </button>
    </nav>
  </Container>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="md:hidden fixed inset-x-0 top-14 bg-warm-black border-b border-sambal-red/40 transform -translate-y-[120%] transition-transform duration-300 ease-out"
    aria-hidden="true"
  >
    <Container>
      <div class="py-4 flex flex-col">
        {navLinks.map((link, index) => (
          <a
            href={link.href}
            class="font-body text-base tracking-[0.2em] uppercase text-bone-white hover:text-sambal-red py-3 border-b border-coconut-cream/10 last:border-0 flex items-center gap-3"
            style={`animation-delay: ${index * 40}ms`}
          >
            <span class="text-sambal-red text-xs tabular-nums">{link.code}</span>
            <span>{link.label}</span>
          </a>
        ))}
      </div>
    </Container>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-14 sm:h-16"></div>

<script>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');
  let isMenuOpen = false;

  // Mobile menu toggle
  mobileMenuBtn?.addEventListener('click', () => {
    isMenuOpen = !isMenuOpen;
    mobileMenuBtn.setAttribute('aria-expanded', String(isMenuOpen));
    mobileMenu?.setAttribute('aria-hidden', String(!isMenuOpen));

    if (isMenuOpen) {
      mobileMenu?.classList.remove('-translate-y-[120%]');
      menuIcon?.classList.add('hidden');
      closeIcon?.classList.remove('hidden');
    } else {
      mobileMenu?.classList.add('-translate-y-[120%]');
      menuIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
    }
  });

  // Close menu on link click
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      isMenuOpen = false;
      mobileMenuBtn?.setAttribute('aria-expanded', 'false');
      mobileMenu?.setAttribute('aria-hidden', 'true');
      mobileMenu?.classList.add('-translate-y-[120%]');
      menuIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
    });
  });
</script>
