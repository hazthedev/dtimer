---
import Container from './Container.astro';
import { MapPin, Clock, Phone } from 'lucide-react';
import siteData from '../data/site.json';

const currentYear = new Date().getFullYear();
---

<footer class="bg-charred-brown text-coconut-cream">
  <Container>
    <div class="py-16 grid grid-cols-1 md:grid-cols-3 gap-12">
      <!-- Brand -->
      <div>
        <h3 class="font-display text-2xl font-bold text-bone-white">D'Timer</h3>
        <p class="mt-3 text-sm leading-relaxed text-coconut-cream/80">
          Johor on a plate. Wangsa Maju, since 2008.
        </p>
        <div class="mt-4 flex items-center gap-4">
          <a href={siteData.social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="text-coconut-cream/70 hover:text-sambal-red transition-colors">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
          </a>
          <a href={siteData.social.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="text-coconut-cream/70 hover:text-sambal-red transition-colors">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
        </div>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-body font-semibold text-bone-white text-sm tracking-wider uppercase">Visit Us</h4>
        <ul class="mt-4 space-y-3 text-sm text-coconut-cream/80">
          <li class="flex items-start gap-3">
            <MapPin size={16} class="mt-0.5 flex-shrink-0 text-sambal-red" />
            <span>
              {siteData.address.street}<br />
              {siteData.address.road}, {siteData.address.section}<br />
              {siteData.address.area}, {siteData.address.postcode} {siteData.address.city}
            </span>
          </li>
          <li class="flex items-center gap-3">
            <Phone size={16} class="flex-shrink-0 text-sambal-red" />
            <a href={`tel:${siteData.phone.replace(/\s/g, '')}`} class="hover:text-bone-white transition-colors">
              {siteData.phone}
            </a>
          </li>
          <li class="flex items-start gap-3">
            <Clock size={16} class="mt-0.5 flex-shrink-0 text-sambal-red" />
            <span>
              Sun – Thu: 2:30pm – 11pm<br />
              Fri – Sat: 2:30pm – 12am
            </span>
          </li>
        </ul>
      </div>

      <!-- Order -->
      <div>
        <h4 class="font-body font-semibold text-bone-white text-sm tracking-wider uppercase">Order Online</h4>
        <div class="mt-4 flex flex-col gap-3">
          <a
            href={siteData.delivery.foodpanda}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center px-5 py-2.5 rounded-lg bg-sambal-red text-bone-white text-sm font-medium hover:bg-[#d13d28] transition-colors"
          >
            FoodPanda
          </a>
          <a
            href={siteData.delivery.grabfood}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center px-5 py-2.5 rounded-lg bg-[#00B14F] text-white text-sm font-medium hover:bg-[#009940] transition-colors"
          >
            GrabFood
          </a>
        </div>
      </div>
    </div>

    <div class="border-t border-coconut-cream/10 py-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-coconut-cream/50">
      <p>© {currentYear} D'Timer Cafe. Company No: {siteData.companyNo}.</p>
      <p>Halal · Family-run since 2008</p>
    </div>
  </Container>
</footer>
