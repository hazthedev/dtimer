---
import Container from './Container.astro';
import { MapPin, Clock, Phone } from 'lucide-react';
import siteData from '../data/site.json';

const currentYear = new Date().getFullYear();
const yearsRunning = currentYear - 2008;
---

<footer class="bg-warm-black text-coconut-cream border-t border-sambal-red/40 relative overflow-hidden">
  <!-- Hairline grid backdrop -->
  <div class="absolute inset-0 bg-void-grid opacity-100 pointer-events-none"></div>

  <!-- Scale ruler at top -->
  <div class="relative border-b border-coconut-cream/15">
    <Container>
      <div class="flex justify-between items-end h-10 font-body text-[0.6rem] tracking-[0.3em] uppercase text-coconut-cream/40">
        <span>D·TMR / WMJ / MY</span>
        <span class="hidden sm:inline">14:30 — 23:00 SUN—THU</span>
        <span class="hidden md:inline">14:30 — 00:00 FRI—SAT</span>
        <span class="text-sambal-red">// LIVE</span>
      </div>
      <div class="flex h-3 items-center gap-px">
        {Array.from({ length: 60 }).map((_, i) => (
          <span class={`w-px ${i % 5 === 0 ? 'h-3 bg-sambal-red' : 'h-1.5 bg-coconut-cream/30'}`}></span>
        ))}
      </div>
    </Container>
  </div>

  <Container>
    <div class="relative py-16 grid grid-cols-1 md:grid-cols-12 gap-10">
      <!-- Brand block -->
      <div class="md:col-span-5">
        <div class="flex items-center gap-3">
          <span class="relative inline-block w-10 h-10 border-2 border-sambal-red">
            <span class="absolute inset-0 m-auto w-1.5 h-1.5 bg-sambal-red rounded-full"></span>
            <span class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-0.5 h-4 bg-bone-white origin-bottom rotate-[120deg]"></span>
          </span>
          <h3 class="font-display text-3xl sm:text-4xl text-bone-white tracking-[0.04em]">D'TIMER</h3>
        </div>
        <p class="mt-5 font-body text-sm leading-relaxed text-coconut-cream/75 max-w-sm">
          Johor on a plate. Wangsa Maju, since 2008.
        </p>

        <!-- Counter row -->
        <div class="mt-8 grid grid-cols-3 gap-3 max-w-sm border-t border-coconut-cream/15 pt-4">
          <div>
            <div class="font-display text-2xl text-sambal-red tabular-nums">{String(yearsRunning).padStart(2,'0')}</div>
            <div class="font-body text-[0.6rem] tracking-[0.3em] uppercase text-coconut-cream/50 mt-1">YRS</div>
          </div>
          <div>
            <div class="font-display text-2xl text-bone-white tabular-nums">{siteData.google.reviewCount}</div>
            <div class="font-body text-[0.6rem] tracking-[0.3em] uppercase text-coconut-cream/50 mt-1">RVWS</div>
          </div>
          <div>
            <div class="font-display text-2xl text-bone-white tabular-nums">{siteData.google.rating}</div>
            <div class="font-body text-[0.6rem] tracking-[0.3em] uppercase text-coconut-cream/50 mt-1">RTNG</div>
          </div>
        </div>

        <div class="mt-6 flex items-center gap-3">
          <a href={siteData.social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="inline-flex items-center justify-center w-9 h-9 border border-coconut-cream/30 text-coconut-cream/70 hover:border-sambal-red hover:text-sambal-red transition-colors">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="0" ry="0"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
          </a>
          <a href={siteData.social.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="inline-flex items-center justify-center w-9 h-9 border border-coconut-cream/30 text-coconut-cream/70 hover:border-sambal-red hover:text-sambal-red transition-colors">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
        </div>
      </div>

      <!-- Contact -->
      <div class="md:col-span-4 md:border-l md:border-coconut-cream/15 md:pl-10">
        <h4 class="font-body text-[0.7rem] tracking-[0.4em] uppercase text-sambal-red flex items-center gap-2">
          <span class="inline-block w-4 h-px bg-sambal-red"></span>
          <span>// 01 — Visit</span>
        </h4>
        <ul class="mt-5 space-y-4 font-body text-sm text-coconut-cream/80">
          <li class="flex items-start gap-3">
            <MapPin size={14} class="mt-0.5 flex-shrink-0 text-sambal-red" />
            <span class="leading-relaxed">
              {siteData.address.street}<br />
              {siteData.address.road}, {siteData.address.section}<br />
              {siteData.address.area}, {siteData.address.postcode} {siteData.address.city}
            </span>
          </li>
          <li class="flex items-center gap-3">
            <Phone size={14} class="flex-shrink-0 text-sambal-red" />
            <a href={`tel:${siteData.phone.replace(/\s/g, '')}`} class="hover:text-bone-white transition-colors tabular-nums tracking-[0.05em]">
              {siteData.phone}
            </a>
          </li>
          <li class="flex items-start gap-3">
            <Clock size={14} class="mt-0.5 flex-shrink-0 text-sambal-red" />
            <span class="leading-relaxed tabular-nums">
              SUN — THU · 14:30 / 23:00<br />
              FRI — SAT · 14:30 / 00:00
            </span>
          </li>
        </ul>
      </div>

      <!-- Order -->
      <div class="md:col-span-3 md:border-l md:border-coconut-cream/15 md:pl-10">
        <h4 class="font-body text-[0.7rem] tracking-[0.4em] uppercase text-sambal-red flex items-center gap-2">
          <span class="inline-block w-4 h-px bg-sambal-red"></span>
          <span>// 02 — Order</span>
        </h4>
        <div class="mt-5 flex flex-col gap-3">
          <a
            href={siteData.delivery.foodpanda}
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center justify-between px-4 py-3 bg-sambal-red text-warm-black font-body text-[0.75rem] tracking-[0.25em] uppercase font-bold border border-sambal-red hover:bg-warm-black hover:text-sambal-red transition-colors"
          >
            <span>FoodPanda</span>
            <span aria-hidden="true">→</span>
          </a>
          <a
            href={siteData.delivery.grabfood}
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center justify-between px-4 py-3 border border-coconut-cream/40 text-bone-white font-body text-[0.75rem] tracking-[0.25em] uppercase font-bold hover:bg-bone-white hover:text-warm-black transition-colors"
          >
            <span>GrabFood</span>
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>

    <div class="relative border-t border-coconut-cream/15 py-5 flex flex-col sm:flex-row items-center justify-between gap-3 font-body text-[0.65rem] tracking-[0.25em] uppercase text-coconut-cream/45">
      <p class="tabular-nums">© {currentYear} D'TIMER CAFE · CO. NO {siteData.companyNo}</p>
      <p class="flex items-center gap-3">
        <span class="inline-flex items-center gap-1.5">
          <span class="w-1.5 h-1.5 bg-sambal-red rounded-full tick-second"></span>
          HALAL
        </span>
        <span>·</span>
        <span>FAMILY-RUN SINCE 2008</span>
      </p>
    </div>
  </Container>
</footer>
