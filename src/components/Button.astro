---
interface Props {
  href?: string;
  variant?: 'primary' | 'outline' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  type?: 'button' | 'submit';
  target?: string;
  rel?: string;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  class: className = '',
  type = 'button',
  target,
  rel
} = Astro.props;

// Brutalist chronograph button — square, mono caps, snap interactions
const baseStyles = 'group relative inline-flex items-center justify-center gap-3 font-body font-bold uppercase tracking-[0.22em] border transition-[transform,background-color,color,box-shadow] duration-150 ease-out focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sambal-red';

const variantStyles = {
  primary: 'bg-sambal-red text-warm-black border-sambal-red hover:bg-warm-black hover:text-sambal-red hover:-translate-x-1 hover:-translate-y-1 hover:shadow-[6px_6px_0_var(--color-sambal-red)] active:translate-x-0 active:translate-y-0 active:shadow-none',
  outline: 'bg-transparent text-warm-black border-warm-black hover:bg-warm-black hover:text-sambal-red hover:-translate-x-1 hover:-translate-y-1 hover:shadow-[6px_6px_0_var(--color-sambal-red)] active:translate-x-0 active:translate-y-0 active:shadow-none',
  ghost:   'bg-transparent text-warm-black border-transparent hover:border-warm-black hover:bg-bone-white active:scale-[0.98]'
};

const sizeStyles = {
  sm: 'px-4 py-2 text-[0.7rem]',
  md: 'px-6 py-3 text-[0.78rem]',
  lg: 'px-7 py-4 text-[0.85rem]'
};

const combinedClasses = `${baseStyles} ${variantStyles[variant]} ${sizeStyles[size]} ${className}`;
---

{href ? (
  <a href={href} class={combinedClasses} target={target} rel={rel}>
    <slot />
    <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">→</span>
  </a>
) : (
  <button type={type} class={combinedClasses}>
    <slot />
    <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">→</span>
  </button>
)}
