---
import Eyebrow from './Eyebrow.astro';

interface Props {
  eyebrow?: string;
  headline: string;
  subheadline?: string;
  align?: 'left' | 'center';
  class?: string;
}

const { eyebrow, headline, subheadline, align = 'center', class: className = '' } = Astro.props;

const alignClass = align === 'center' ? 'text-center mx-auto' : 'text-left';
const maxWidth = align === 'center' ? 'max-w-3xl mx-auto' : 'max-w-3xl';
---

<div class={`${alignClass} ${maxWidth} ${className}`}>
  {eyebrow && (
    <div class={`flex items-center gap-3 ${align === 'center' ? 'justify-center' : ''}`}>
      <span class="inline-block w-8 h-px bg-sambal-red"></span>
      <span class="font-body text-[0.7rem] tracking-[0.4em] uppercase text-warm-black">{eyebrow}</span>
      <span class="inline-block w-8 h-px bg-sambal-red"></span>
    </div>
  )}
  <h2 class="mt-5 font-display text-3xl sm:text-5xl lg:text-6xl font-normal text-warm-black leading-[1.0] tracking-[0.01em] uppercase">
    {headline}
  </h2>
  {subheadline && (
    <p class="mt-5 font-body text-base sm:text-lg text-tea-brown leading-relaxed max-w-2xl" class:list={[align === 'center' ? 'mx-auto' : '']}>
      {subheadline}
    </p>
  )}
</div>
