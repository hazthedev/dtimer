---
import Eyebrow from './Eyebrow.astro';

interface Props {
  eyebrow?: string;
  headline: string;
  subheadline?: string;
  align?: 'left' | 'center';
  class?: string;
}

const { eyebrow, headline, subheadline, align = 'center', class: className = '' } = Astro.props;

const alignClass = align === 'center' ? 'text-center mx-auto' : 'text-left';
const maxWidth = align === 'center' ? 'max-w-2xl mx-auto' : 'max-w-2xl';
---

<div class={`${alignClass} ${maxWidth} ${className}`}>
  {eyebrow && <Eyebrow text={eyebrow} class={align === 'center' ? 'justify-center' : ''} />}
  <h2 class="mt-3 font-display text-3xl sm:text-4xl lg:text-5xl font-semibold text-warm-black leading-tight">
    {headline}
  </h2>
  {subheadline && (
    <p class="mt-4 text-base sm:text-lg text-tea-brown leading-relaxed max-w-xl" class:list={[align === 'center' ? 'mx-auto' : '']}>
      {subheadline}
    </p>
  )}
</div>
